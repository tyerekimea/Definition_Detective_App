# AI Configuration

# DeepSeek Configuration (Primary - Recommended)
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Google Generative AI Configuration (Fallback)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
GEMINI_API_KEY=your_google_genai_api_key_here

# Optional: Specify a specific model to use
# GOOGLE_GENAI_MODEL=openai/deepseek-chat

# Optional: Specify comma-separated list of model candidates to try
# GOOGLE_GENAI_MODEL_CANDIDATES=openai/deepseek-chat,openai/deepseek-reasoner,googleai/gemini-2.5-flash

# Optional hint-flow timeout tuning (milliseconds)
# HINT_MODEL_TIMEOUT_MS=9000
# HINT_FLOW_TIMEOUT_MS=25000

# Optional word-flow timeout tuning (milliseconds)
# WORD_MODEL_TIMEOUT_MS=9000
# WORD_FLOW_TIMEOUT_MS=25000

# Available models (as of 2026):
# - deepseek-chat (recommended)
# - deepseek-reasoner
# - googleai/gemini-2.5-flash
# - googleai/gemini-2.5-pro
# - googleai/gemini-2.5-flash-lite
# NOTE: `googleai/gemini-2.0-flash-exp` is deprecated/unsupported for this flow.

# Firebase Configuration
# Get your Firebase config from: https://console.firebase.google.com/
# Go to Project Settings > General > Your apps > Web app

# Option 1: Individual environment variables (recommended for development)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-MEASUREMENT_ID

# Option 2: JSON configuration (for Firebase App Hosting)
# FIREBASE_CONFIG={"projectId":"your-project-id","apiKey":"your-api-key","authDomain":"your-project-id.firebaseapp.com","storageBucket":"your-project-id.appspot.com","messagingSenderId":"your-sender-id","appId":"your-app-id"}

# Firebase Admin SDK (Server-side only - NOT for client code)
# These should NEVER be shared or stored in source control
# Only set in .env.local (which is .gitignore'd)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Paystack Configuration
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here
# Optional explicit CORS allowlist for verify endpoint (comma-separated origins)
# Example: PAYSTACK_VERIFY_ALLOWED_ORIGINS=https://traylapps.com,https://www.traylapps.com
PAYSTACK_VERIFY_ALLOWED_ORIGINS=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional explicit API base URL (useful for mobile/static builds)
# Example: NEXT_PUBLIC_API_BASE_URL=https://api.traylapps.com
NEXT_PUBLIC_API_BASE_URL=

# Build configuration
# IMPORTANT: Keep MOBILE_BUILD unset/false for web deployments (e.g. Vercel),
# otherwise Next.js API routes like /api/paystack/verify and /api/paystack/webhook
# are not generated and payment verification will fail.
# This project already enforces it automatically:
# - `npm run build` forces MOBILE_BUILD=false (web/server build)
# - `npm run build:mobile` forces MOBILE_BUILD=true (Capacitor static build)
# MOBILE_BUILD=true
