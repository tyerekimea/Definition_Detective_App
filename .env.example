# AI Configuration

# OpenAI Configuration (Primary - Recommended)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Generative AI Configuration (Fallback)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here
GEMINI_API_KEY=your_google_genai_api_key_here

# Optional: Specify a specific model to use
# GOOGLE_GENAI_MODEL=googleai/gemini-1.5-flash-latest

# Optional: Specify comma-separated list of model candidates to try
# GOOGLE_GENAI_MODEL_CANDIDATES=googleai/gemini-1.5-flash-latest,googleai/gemini-1.5-pro-latest

# Available models (as of 2026):
# - googleai/gemini-1.5-flash-latest (recommended - fast and efficient)
# - googleai/gemini-1.5-pro-latest (more capable)
# - googleai/gemini-2.0-flash-exp (experimental, latest features)
# - googleai/gemini-pro (stable fallback)

# Firebase Configuration
# Get your Firebase config from: https://console.firebase.google.com/
# Go to Project Settings > General > Your apps > Web app

# Option 1: Individual environment variables (recommended for development)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-MEASUREMENT_ID

# Option 2: JSON configuration (for Firebase App Hosting)
# FIREBASE_CONFIG={"projectId":"your-project-id","apiKey":"your-api-key","authDomain":"your-project-id.firebaseapp.com","storageBucket":"your-project-id.appspot.com","messagingSenderId":"your-sender-id","appId":"your-app-id"}

# Firebase Admin SDK (Server-side only - NOT for client code)
# These should NEVER be shared or stored in source control
# Only set in .env.local (which is .gitignore'd)
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Paystack Configuration
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
