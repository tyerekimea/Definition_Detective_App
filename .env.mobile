# Stub environment variables for mobile builds
# These are needed during the build process but won't be used in the final app

# Payment processing (API only, not used in mobile)
PAYSTACK_SECRET_KEY=mobile_build_stub

# Firebase Admin (API only)
FIREBASE_PRIVATE_KEY=mobile_build_stub
FIREBASE_PROJECT_ID=mobile_build_stub
FIREBASE_CLIENT_EMAIL=mobile_build_stub

# OpenAI (for word generation flow, will use mocks)
OPENAI_API_KEY=mobile_build_stub

# Genkit (AI generation, will use mocks)
GENKIT_API_KEY=mobile_build_stub
