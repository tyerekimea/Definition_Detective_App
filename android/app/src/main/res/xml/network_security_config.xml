<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production domains - HTTPS only -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">traylapps.com</domain>
        <domain includeSubdomains="true">definition-detective-app.vercel.app</domain>
    </domain-config>

    <!-- Development domain - Allow cleartext for localhost testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>

    <!-- Default policy - do not allow cleartext -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">.</domain>
    </domain-config>
</network-security-config>
